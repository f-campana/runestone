---
import { getCollection, render } from 'astro:content';
import PressLayout from '../../components/PressLayout.astro';
import RadarRow from '../../components/RadarRow.astro';
import RuneHero from '../../components/RuneHero.astro';

export async function getStaticPaths() {
  const runes = await getCollection('runes');
  return runes.map(rune => ({
    params: { slug: rune.id },
    props: { rune },
  }));
}

const { rune } = Astro.props;
const { Content } = await render(rune);
const radarValues = rune.data.radar.split('-').map(Number);
const radarRows = [
  {
    label: 'Density',
    interpretation: 'Purposeful — space is earned, not assumed. Components fill their container without cramping. No generous padding for its own sake.',
  },
  {
    label: 'Temperature',
    interpretation: 'Controlled neutral — neither warm nor cold. The orange provides energy without warmth. Off-white base is paper, not skin.',
  },
  {
    label: 'Luminosity',
    interpretation: 'Light-first — white base, dark type, orange structure. No dark mode variant in this rune. Contrast is maximum, always.',
  },
  {
    label: 'Energy',
    interpretation: 'Kinetic — hard press animations, snap transitions, no spring physics. Motion feels mechanical, not organic.',
  },
  {
    label: 'Geometry',
    interpretation: 'Fully geometric — border-radius: 0 everywhere without exception. Grid is visible and rigid. Asymmetry is permitted; softness is not.',
  },
  {
    label: 'Chromatism',
    interpretation: 'Near-monochrome — one structural colour (orange). Black, white, and off-white carry everything else. No secondary accent.',
  },
  {
    label: 'Depth',
    interpretation: 'Restrained — no box-shadows. Depth is created by border weight and background contrast alone. 2px borders at 0 radius read as physical objects stacked on a surface.',
  },
  {
    label: 'Posture',
    interpretation: 'Assertive — the interface has a point of view. It does not recede behind content. It frames it with authority.',
  },
];
---

<PressLayout title={`${rune.data.name} — Runestone`}>
  <RuneHero
    name={rune.data.name}
    status={rune.data.status}
    archetypes={rune.data.archetypes}
    version={rune.data.version}
    namespace={rune.data.namespace}
    test_sentence={rune.data.test_sentence}
  />

  <!-- RADAR -->
  <section style="
    padding: var(--pr-section-pad) var(--pr-page-margin);
    background: var(--pr-surface-mid);
    border-bottom: 2px solid var(--pr-border);
  ">
    <div style="max-width: var(--pr-max-width); margin: 0 auto;">
      <div style="
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        border-bottom: 2px solid var(--pr-border);
        padding-bottom: 10px;
        margin-bottom: 24px;
      ">
        <h2 style="font-family:var(--pr-font-display);font-size:22px;font-weight:800;letter-spacing:-0.03em;">Radar</h2>
        <span style="font-family:var(--pr-font-mono);font-size:9px;letter-spacing:.1em;color:var(--pr-orange);">{rune.data.radar}</span>
      </div>
      <div class="radar-list" style="display:grid;gap:0;border:2px solid var(--pr-border);background:var(--pr-surface);padding:0 16px;">
        {radarRows.map((row, i) => (
          <RadarRow label={row.label} score={radarValues[i]} interpretation={row.interpretation} />
        ))}
      </div>
    </div>
  </section>

  <!-- CONTENT -->
  <section style="
    padding: var(--pr-section-pad) var(--pr-page-margin);
    background: var(--pr-surface-bg);
  ">
    <div style="max-width: var(--pr-max-width); margin: 0 auto;">
      <div class="rune-content">
        <Content />
      </div>
    </div>
  </section>

</PressLayout>

<style>
  .rune-content h2 {
    font-family: var(--pr-font-display);
    font-size: clamp(18px, 2.5vw, 28px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--pr-text);
    margin: 48px 0 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--pr-border);
  }
  .radar-list :global(.radar-row:last-child) {
    border-bottom: 0;
  }
  .rune-content h3 {
    font-family: var(--pr-font-display);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--pr-text);
    margin: 28px 0 10px;
  }
  .rune-content p {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--pr-text-2);
    margin-bottom: 14px;
    max-width: 680px;
  }
  .rune-content pre {
    font-family: var(--pr-font-mono);
    font-size: 11px;
    line-height: 1.8;
    background: var(--pr-surface-mid);
    border: 2px solid var(--pr-border);
    padding: 16px;
    overflow-x: auto;
    margin: 16px 0;
  }
  .rune-content code {
    font-family: var(--pr-font-mono);
    font-size: 10px;
    background: var(--pr-orange-dim);
    color: var(--pr-orange);
    padding: 1px 5px;
    border: 1px solid rgba(232,78,8,.2);
  }
  .rune-content pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--pr-text-2);
  }
  .rune-content table {
    width: 100%;
    border-collapse: collapse;
    border: 2px solid var(--pr-border);
    margin: 16px 0;
  }
  .rune-content th {
    font-family: var(--pr-font-mono);
    font-size: 8px;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 8px 12px;
    text-align: left;
    background: var(--pr-surface-mid);
    border-bottom: 2px solid var(--pr-border);
    color: var(--pr-text-3);
  }
  .rune-content td {
    font-size: 12px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--pr-border-light);
    color: var(--pr-text-2);
  }
  .rune-content ul, .rune-content ol {
    padding-left: 0;
    list-style: none;
    margin: 12px 0;
  }
  .rune-content li {
    font-size: 13px;
    font-weight: 300;
    color: var(--pr-text-2);
    padding: 4px 0 4px 16px;
    position: relative;
    border-bottom: 1px solid var(--pr-border-light);
  }
  .rune-content li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--pr-text-3);
    font-size: 10px;
  }
  .rune-content strong {
    font-weight: 500;
    color: var(--pr-text);
  }
</style>
