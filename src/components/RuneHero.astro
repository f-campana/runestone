---
export interface Props {
  name: string;
  status: string;
  archetypes: string[];
  version: string;
  namespace: string;
  test_sentence: string;
}

const { name, status, archetypes, version, namespace, test_sentence } = Astro.props;
const archetypeLabel = archetypes.join(' + ');
const namespaceLabel = namespace.startsWith('--') ? namespace : `--${namespace}-`;
---

<section class="rune-hero">
  <div class="rune-hero__inner">
    <div class="rune-hero__eyebrow">
      <span class="rune-hero__rule" aria-hidden="true"></span>
      <span>Design identity &middot; {status}</span>
    </div>

    <div class="rune-hero__title-frame">
      <h1 class="rune-hero__title">{name}</h1>
    </div>

    <div class="rune-hero__meta" aria-label="Rune identity metadata">
      <div class="rune-hero__meta-cell">
        <div class="rune-hero__meta-label">Archetypes</div>
        <div class="rune-hero__meta-value rune-hero__meta-value--display">{archetypeLabel}</div>
      </div>
      <div class="rune-hero__meta-cell">
        <div class="rune-hero__meta-label">Version</div>
        <div class="rune-hero__meta-value">{version}</div>
      </div>
      <div class="rune-hero__meta-cell">
        <div class="rune-hero__meta-label">Namespace</div>
        <div class="rune-hero__meta-value">{namespaceLabel}</div>
      </div>
    </div>

    <p class="rune-hero__test-sentence">{test_sentence}</p>
  </div>
</section>

<style>
  .rune-hero {
    padding: var(--pr-section-pad) var(--pr-page-margin);
    border-bottom: 2px solid var(--pr-border);
    background: var(--pr-surface-bg);
  }

  .rune-hero__inner {
    max-width: var(--pr-max-width);
    margin: 0 auto;
  }

  .rune-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    font-family: var(--pr-font-mono);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.18em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--pr-text-2);
  }

  .rune-hero__rule {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--pr-orange);
  }

  .rune-hero__title-frame {
    overflow: hidden;
    margin-bottom: 24px;
  }

  .rune-hero__title {
    font-family: var(--pr-font-display);
    font-size: clamp(32px, 4vw, 64px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.92;
    color: var(--pr-text);
  }

  .rune-hero__meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin-bottom: 32px;
    border: 2px solid var(--pr-border);
    background: var(--pr-surface);
  }

  .rune-hero__meta-cell {
    padding: 10px 16px;
  }

  .rune-hero__meta-label {
    margin-bottom: 4px;
    font-family: var(--pr-font-mono);
    font-size: 8px;
    font-weight: 400;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--pr-text-3);
  }

  .rune-hero__meta-value {
    font-family: var(--pr-font-mono);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--pr-text);
  }

  .rune-hero__meta-value--display {
    font-family: var(--pr-font-display);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .rune-hero__test-sentence {
    max-width: 680px;
    font-family: var(--pr-font-body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--pr-text-2);
  }

  @media (min-width: 721px) {
    .rune-hero__meta {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .rune-hero__meta-cell + .rune-hero__meta-cell {
      border-left: 2px solid var(--pr-border);
    }
  }

  @media (max-width: 720px) {
    .rune-hero__meta-cell + .rune-hero__meta-cell {
      border-top: 2px solid var(--pr-border);
    }
  }
</style>
