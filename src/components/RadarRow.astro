---
export interface Props {
  label: string;
  score: number;
  interpretation: string;
}

const { label, score, interpretation } = Astro.props;
const boundedScore = Math.min(10, Math.max(1, score));
const fillWidth = `${boundedScore * 10}%`;
---

<div class="radar-row">
  <div class="radar-row__header">
    <div class="radar-row__label">{label}</div>
    <div class="radar-row__score">{score}</div>
  </div>
  <div class="radar-row__track" aria-hidden="true">
    <div class="radar-row__fill" style={`width: ${fillWidth};`}></div>
  </div>
  <p class="radar-row__interpretation">{interpretation}</p>
</div>

<style>
  .radar-row {
    display: grid;
    gap: 8px;
    padding: 12px 0;
    border-bottom: 2px solid var(--pr-border-light);
  }

  .radar-row__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }

  .radar-row__label {
    font-family: var(--pr-font-mono);
    font-size: 8px;
    font-weight: 400;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--pr-text-3);
  }

  .radar-row__score {
    font-family: var(--pr-font-mono);
    font-size: 13px;
    font-weight: 500;
    line-height: 1;
    color: var(--pr-text);
  }

  .radar-row__track {
    width: 100%;
    height: 2px;
    background: var(--pr-border-light);
  }

  .radar-row__fill {
    height: 2px;
    background: var(--pr-orange);
  }

  .radar-row__interpretation {
    font-family: var(--pr-font-body);
    font-size: 11px;
    font-weight: 300;
    line-height: 1.5;
    color: var(--pr-text-2);
  }
</style>
